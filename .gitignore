# ============================================================================
# Multi-Task Medical Imaging: OA & OP Classification
# Comprehensive .gitignore for ML project
# ============================================================================

# ============================================================================
# DATA FILES (Do NOT commit large datasets)
# ============================================================================
data/raw/
data/processed/
*.zip
*.tar
*.tar.gz
*.rar
!data/.gitkeep

# ============================================================================
# MODEL CHECKPOINTS & WEIGHTS (Too large for git, use Git LFS or cloud storage)
# ============================================================================
checkpoints/
*.pth
*.pt
*.ckpt
*.pkl
*.pickle
!checkpoints/.gitkeep

# ============================================================================
# RESULTS & OUTPUTS
# ============================================================================
results/
outputs/
*.csv
*.json
!results/.gitkeep

# ============================================================================
# NOTEBOOKS & JUPYTER
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
.jupyter/
jupyter_config.py

# ============================================================================
# PYTHON VIRTUAL ENVIRONMENTS
# ============================================================================
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
conda-env.txt
environment.yml

# ============================================================================
# PYTHON CACHE & COMPILATION
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
*.sublime-project
.project
.pydevproject
.classpath
.c9/

# ============================================================================
# SYSTEM FILES
# ============================================================================
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
desktop.ini
ehthumbs.db

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
logs/
*.tmp
*.temp
temp/
.tmp/

# ============================================================================
# OS-SPECIFIC FILES
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ============================================================================
# TESTING & DEBUGGING
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.pylint.d/

# ============================================================================
# LARGE AUXILIARY FILES
# ============================================================================
*.mp4
*.avi
*.mov
*.mkv
*.zip
*.gz
*.7z
*.rar

# ============================================================================
# SPECIFIC TO THIS PROJECT
# ============================================================================
anaconda_projects/db/
*.~
.~lock*

# ============================================================================
# DOCUMENTATION BUILD
# ============================================================================
docs/_build/
site/
.sphinx/

# ============================================================================
# OPTIONAL: GIT LFS - Uncomment if using Git LFS for large files
# ============================================================================
# *.pth
# *.pt
# *.csv
# data/raw/

# ============================================================================
# ALLOW THESE FILES (Important for project)
# ============================================================================
!.gitignore
!.gitattributes
!.github/
!requirements.txt
!README.md
!QUICK_REFERENCE.md
!create_sample_data.py
!multi_task_medical_imaging_updated.ipynb
